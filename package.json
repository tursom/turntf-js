{
  "name": "@tursom/turntf-js",
  "version": "0.1.0",
  "description": "Node.js SDK for turntf.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:proto": "protoc -I proto --ts_out src/generated --ts_opt long_type_string proto/client.proto",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1",
    "bcryptjs": "^3.0.2",
    "json-bigint": "^1.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
